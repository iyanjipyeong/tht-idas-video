APP_ADDR=:8080

# Driver alias used by the application bootstrap
DATABASE_DRIVER=pgx

# PostgreSQL connection settings
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=idas_video
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=development
DATABASE_SSLMODE=disable

# Schema migration target; keep public unless you intentionally separate schemas
DATABASE_SCHEMA=public
DATABASE_TIMEZONE=Asia/Jakarta

# Directory containing SQL migrations
MIGRATION_DIR=migrations
